# AgentOS — variables de entorno del agente (PLANTILLA)
#
# En el celular-servidor (Termux) copia este archivo a `.env` y rellena los valores.
# En la app Android estas claves NO se ponen en un archivo: se configuran desde
# Settings → Env Vars y quedan cifradas en Android Keystore.
#
# NUNCA subas tu `.env` real al repositorio (está en .gitignore).

# --- Núcleo ---
TELEGRAM_TOKEN=
OWNER_ID=
CITY=

# --- Proveedores LLM (multi-proveedor con failover; pon al menos uno) ---
GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
SAMBANOVA_API_KEY=
FREELLMAPI_UNIFIED_KEY=

# --- Integraciones opcionales ---
GITHUB_TOKEN=
